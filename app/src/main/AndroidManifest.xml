<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Network Access for Supabase API (songs, genres) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Camera Access -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- Photo Library Access -->
    <!-- Android 13+ (API 33+) -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <!-- Android 14+ (API 34+): Limited photo access -->
    <uses-permission android:name="android.permission.READ_MEDIA_VISUAL_USER_SELECTED" />

    <!-- Audio Library Access (for custom background music) -->
    <!-- Android 13+ (API 33+) -->
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />

    <uses-permission android:name="android.permission.REQUEST_DELETE_PACKAGES" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Android 12 and below -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <application
        android:name=".VideoMakerApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:localeConfig="@xml/locales_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.VideoMaker"
        tools:replace="android:dataExtractionRules,android:fullBackupContent">

        <!-- RootViewActivity - Entry Point (Launcher)
             Applies locale, shows splash, routes to Language or Main -->
        <activity
            android:name=".RootViewActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.App.Starting">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity>

        <!-- OnboardingActivity - First-time user onboarding (separate one-time flow) -->
        <activity
            android:name=".modules.onboarding.OnboardingActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.VideoMaker" />

        <activity
            android:name=".modules.featureselection.FeatureSelectionActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.VideoMaker" />

        <!-- LanguageSelectionActivity - First-time language picker
             configChanges: handle locale/layoutDirection ourselves so the Activity is NOT
             recreated when AppCompatDelegate.setApplicationLocales() is called on Continue.
             The Activity finishes immediately after, so no UI refresh is needed. -->
        <activity
            android:name=".modules.language.LanguageSelectionActivity"
            android:configChanges="locale|layoutDirection"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.VideoMaker" />

        <!-- MainActivity - Main app content (no longer launcher) -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.VideoMaker"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="com.videomaker.aimusic.action.OPEN_SEARCH" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <intent-filter>
                <action android:name="com.videomaker.aimusic.action.OPEN_TRENDING_SONG" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <intent-filter>
                <action android:name="com.videomaker.aimusic.action.OPEN_TRENDING_TEMPLATE" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <intent-filter>
                <action android:name="com.videomaker.aimusic.action.CREATE_VIDEO" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <intent-filter>
                <action android:name="com.videomaker.aimusic.action.UNINSTALL_APP" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- ============================================ -->
        <!-- WIDGET RECEIVERS (Glance AppWidgets) -->
        <!-- ============================================ -->
        <receiver
            android:name=".widget.appwidget.SmartSearchWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_smart_search">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_search_info" />
        </receiver>

        <receiver
            android:name=".widget.appwidget.TrendingSongWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_trending_song">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_trending_song_info" />
        </receiver>

        <receiver
            android:name=".widget.appwidget.TrendingTemplateWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_trending_template">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_trending_template_info" />
        </receiver>

        <!-- FileProvider for sharing exported videos -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- AppLocalesMetadataHolderService for per-app language support on Android 12 and lower -->
        <service
            android:name="androidx.appcompat.app.AppLocalesMetadataHolderService"
            android:enabled="false"
            android:exported="false">
            <meta-data
                android:name="autoStoreLocales"
                android:value="true" />
        </service>

        <!-- ============================================ -->
        <!-- ANALYTICS & ADS SDKs -->
        <!-- ============================================ -->

        <!-- Facebook SDK Configuration (for Analytics only) -->
        <meta-data
            android:name="com.facebook.sdk.ApplicationId"
            android:value="@string/facebook_app_id" />
        <meta-data
            android:name="com.facebook.sdk.ClientToken"
            android:value="@string/facebook_client_token" />

        <!-- AdMob App ID (required for AdMob SDK) -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-7121075950716954~9970460257"/>

    </application>

</manifest>
