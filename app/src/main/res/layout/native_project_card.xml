<?xml version="1.0" encoding="utf-8"?>
<!--
Native Ad Layout: Project Card (16:9 Landscape)
- Wide landscape layout matching 16:9 project cards
- Large media view at top in 16:9 format
- Horizontal info bar below (icon + headline + CTA)
- Ad badge at top-right corner
- Use case: In-feed placement within created projects grid
-->
<com.google.android.gms.ads.nativead.NativeAdView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent">

    <!-- Container matching ProjectCard style -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/foundation_black">

        <!-- Media View (top section - 16:9 landscape) -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Ad Media (wide landscape view - 16:9 ratio) -->
            <com.google.android.gms.ads.nativead.MediaView
                android:id="@+id/ad_media"
                android:layout_width="match_parent"
                android:layout_height="101dp"
                android:scaleType="centerCrop"
                android:background="@color/foundation_black" />

            <!-- Ad Badge at top-right -->
            <TextView
                android:id="@+id/ad_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="6dp"
                android:text="@string/ad_badge"
                android:textSize="9sp"
                android:textColor="#FFE5E5E5"
                android:textStyle="bold"
                android:background="@drawable/bg_template_badge"
                android:paddingHorizontal="6dp"
                android:paddingVertical="4dp"
                android:minWidth="28dp"
                android:gravity="center" />
        </FrameLayout>

        <!-- Info Section (bottom - horizontal bar like native_big_row) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="horizontal"
            android:layout_marginTop="101dp"
            android:padding="10dp"
            android:gravity="center_vertical"
            android:background="@color/foundation_black">

            <!-- App Icon (compact) -->
            <ImageView
                android:id="@+id/ad_icon"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:scaleType="fitCenter"
                android:contentDescription="@string/ad_icon"
                android:layout_marginEnd="10dp" />

            <!-- Headline + Body (vertical stack, takes remaining space) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="10dp">

                <!-- Headline (2 lines max) -->
                <TextView
                    android:id="@+id/ad_headline"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@color/foundation_white"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:lineHeight="18dp" />

                <!-- Body text (1 line, subtle) -->
                <TextView
                    android:id="@+id/ad_body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="@color/foundation_white_60"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- CTA Button (compact, vertical) -->
            <TextView
                android:id="@+id/ad_call_to_action"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:gravity="center"
                android:textSize="13sp"
                android:textColor="@color/foundation_black"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_cta_clean"
                android:paddingHorizontal="16dp"
                android:minWidth="75dp"
                android:textAllCaps="false" />

            <!-- Hidden fields (required by NativeAdView but not displayed) -->
            <TextView
                android:id="@+id/ad_advertiser"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/ad_store"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- AdChoices overlay at top-right -->
        <FrameLayout
            android:id="@+id/ad_choices_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:padding="4dp" />
    </FrameLayout>
</com.google.android.gms.ads.nativead.NativeAdView>
