<?xml version="1.0" encoding="utf-8"?>
<!--
Native Ad Layout: Project Card (9:16 Portrait)
- Tall portrait layout matching 9:16 project cards
- Large media view at top (280dp)
- Prominent title with more space
- Large, eye-catching CTA button
- Ad badge at top-right corner
- Use case: In-feed placement within created projects grid
-->
<com.google.android.gms.ads.nativead.NativeAdView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent">

    <!-- Container with rounded corners matching ProjectCard -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/foundation_black">

        <!-- Media View (top section - larger for 9:16 ratio) -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Ad Media (larger portrait view) -->
            <com.google.android.gms.ads.nativead.MediaView
                android:id="@+id/ad_media"
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:scaleType="centerCrop"
                android:background="@color/foundation_black" />

            <!-- Ad Badge at top-right (styled like duration badge) -->
            <TextView
                android:id="@+id/ad_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="8dp"
                android:text="@string/ad_badge"
                android:textSize="10sp"
                android:textColor="#FFE5E5E5"
                android:textStyle="bold"
                android:background="@drawable/bg_template_badge"
                android:paddingHorizontal="8dp"
                android:paddingVertical="5dp"
                android:minWidth="32dp"
                android:gravity="center" />
        </FrameLayout>

        <!-- Info Section (bottom - more spacious layout) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:layout_marginTop="280dp"
            android:padding="12dp"
            android:background="@color/foundation_black">

            <!-- App Icon + Headline (more vertical space) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <!-- App Icon (slightly larger) -->
                <ImageView
                    android:id="@+id/ad_icon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:scaleType="fitCenter"
                    android:contentDescription="@string/ad_icon"
                    android:layout_marginEnd="10dp" />

                <!-- Headline (larger, more prominent, 2 lines) -->
                <TextView
                    android:id="@+id/ad_headline"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="15sp"
                    android:textColor="@color/foundation_white"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:lineHeight="20dp" />
            </LinearLayout>

            <!-- Body text (optional, more visible) -->
            <TextView
                android:id="@+id/ad_body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/foundation_white_60"
                android:maxLines="2"
                android:ellipsize="end"
                android:lineHeight="16dp"
                android:layout_marginBottom="12dp" />

            <!-- CTA Button (larger, full-width, prominent) -->
            <TextView
                android:id="@+id/ad_call_to_action"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:gravity="center"
                android:textSize="14sp"
                android:textColor="@color/foundation_black"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_cta_clean"
                android:paddingHorizontal="20dp"
                android:textAllCaps="false" />

            <!-- Hidden fields (required by NativeAdView but not displayed) -->
            <TextView
                android:id="@+id/ad_advertiser"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/ad_store"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- AdChoices overlay at top-right -->
        <FrameLayout
            android:id="@+id/ad_choices_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:padding="4dp" />
    </FrameLayout>
</com.google.android.gms.ads.nativead.NativeAdView>
