<?xml version="1.0" encoding="utf-8"?>
<!--
Native Ad Layout: Project Card (9:16 Portrait)
- Compact layout with minimal padding
- Very small CTA button to prevent overflow
- Use case: In-feed placement within created projects grid
-->
<com.google.android.gms.ads.nativead.NativeAdView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent">

    <!-- Container matching ProjectCard style -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/foundation_black">

        <!-- Media View (top section - compact) -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Ad Media (compact portrait view) -->
            <com.google.android.gms.ads.nativead.MediaView
                android:id="@+id/ad_media"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:scaleType="centerCrop"
                android:background="@color/foundation_black" />

            <!-- Ad Badge at top-right -->
            <TextView
                android:id="@+id/ad_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="6dp"
                android:text="@string/ad_badge"
                android:textSize="9sp"
                android:textColor="#FFE5E5E5"
                android:textStyle="bold"
                android:background="@drawable/bg_template_badge"
                android:paddingHorizontal="6dp"
                android:paddingVertical="3dp"
                android:minWidth="24dp"
                android:gravity="center" />
        </FrameLayout>

        <!-- Info Section (bottom - very compact) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:layout_marginTop="180dp"
            android:padding="8dp"
            android:background="@color/foundation_black">

            <!-- Icon + Headline Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <!-- App Icon (small) -->
                <ImageView
                    android:id="@+id/ad_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:scaleType="fitCenter"
                    android:contentDescription="@string/ad_icon"
                    android:layout_marginEnd="6dp" />

                <!-- Headline (small font, 2 lines) -->
                <TextView
                    android:id="@+id/ad_headline"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="12sp"
                    android:textColor="@color/foundation_white"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:lineHeight="16dp" />
            </LinearLayout>

            <!-- Body text (very compact, 1 line) -->
            <TextView
                android:id="@+id/ad_body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="@color/foundation_white_60"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginBottom="6dp" />

            <!-- CTA Button (very small, minimal padding) -->
            <TextView
                android:id="@+id/ad_call_to_action"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:gravity="center"
                android:textSize="11sp"
                android:textColor="@color/foundation_black"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_cta_clean"
                android:paddingHorizontal="8dp"
                android:textAllCaps="false"
                android:maxLines="1"
                android:ellipsize="end"
                android:includeFontPadding="false" />

            <!-- Hidden fields (required by NativeAdView but not displayed) -->
            <TextView
                android:id="@+id/ad_advertiser"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/ad_store"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- AdChoices overlay at top-right -->
        <FrameLayout
            android:id="@+id/ad_choices_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:padding="4dp" />
    </FrameLayout>
</com.google.android.gms.ads.nativead.NativeAdView>
