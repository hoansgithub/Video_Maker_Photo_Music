<?xml version="1.0" encoding="utf-8"?>
<!--
Native Ad Layout: Small Row
- Horizontal list layout for in-feed placements
- Logo icon on left (80dp width, 100dp height)
- Content on right (title, body, CTA)
- Dark background for ad distinction
- Amber ad badge for disclosure
- Use case: Search results in-feed placement
-->
<com.google.android.gms.ads.nativead.NativeAdView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/foundation_black"
    android:paddingHorizontal="16dp"
    android:paddingVertical="8dp">

    <!-- Horizontal layout: Logo on left, Content on right -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:minHeight="100dp">

        <!-- Logo container with Ad Badge overlay (left side - fixed 80dp width) -->
        <FrameLayout
            android:layout_width="80dp"
            android:layout_height="100dp"
            android:layout_marginEnd="12dp"
            android:background="@color/foundation_black">

            <!-- App Icon/Logo centered -->
            <ImageView
                android:id="@+id/ad_icon"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center"
                android:scaleType="fitCenter"
                android:contentDescription="@string/ad_icon" />

            <!-- Ad Badge overlay at top-left -->
            <TextView
                android:id="@+id/ad_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:text="@string/ad_badge"
                android:textSize="9sp"
                android:textColor="@color/foundation_black"
                android:textStyle="bold"
                android:background="@drawable/bg_ad_badge"
                android:paddingHorizontal="5dp"
                android:paddingVertical="2dp"
                android:layout_margin="4dp" />
        </FrameLayout>

        <!-- Content area (right side - remaining space) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_gravity="center_vertical"
            android:orientation="vertical"
            android:paddingVertical="4dp">

            <!-- Top row: Title and CTA button -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <!-- Title/Headline (takes remaining space on left) -->
                <TextView
                    android:id="@+id/ad_headline"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="14sp"
                    android:textColor="@color/foundation_white"
                    android:textStyle="normal"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:lineSpacingMultiplier="1.2"
                    android:layout_marginEnd="8dp" />

                <!-- CTA Button (bigger, on the right) -->
                <TextView
                    android:id="@+id/ad_call_to_action"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:gravity="center"
                    android:textSize="13sp"
                    android:textColor="@color/foundation_black"
                    android:textStyle="bold"
                    android:background="@drawable/bg_cta_clean"
                    android:paddingHorizontal="16dp"
                    android:minWidth="80dp" />
            </LinearLayout>

            <!-- Body text (subtle) -->
            <TextView
                android:id="@+id/ad_body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/foundation_white_60"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Optional: Advertiser name (hidden if not provided) -->
            <TextView
                android:id="@+id/ad_advertiser"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="9sp"
                android:textColor="@color/foundation_white_40"
                android:maxLines="1"
                android:ellipsize="end"
                android:visibility="gone" />

            <!-- Optional: Store name (hidden if not provided) -->
            <TextView
                android:id="@+id/ad_store"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="9sp"
                android:textColor="@color/foundation_white_40"
                android:maxLines="1"
                android:ellipsize="end"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <!-- AdChoices overlay at top-right of entire ad -->
    <FrameLayout
        android:id="@+id/ad_choices_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:padding="4dp" />
</com.google.android.gms.ads.nativead.NativeAdView>
