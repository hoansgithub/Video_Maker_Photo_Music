<?xml version="1.0" encoding="utf-8"?>
<!--
Native Ad Layout: Small Clean
- Compact horizontal layout (200dp height)
- Media on left (55%), content on right (45%)
- Clean CTA button styled with app theme
- Dark background with ad badge disclosure
- Use case: In-content placements (home feed, song list, project list)
-->
<com.google.android.gms.ads.nativead.NativeAdView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="200dp"
    android:background="@color/foundation_black">

    <!-- Horizontal layout: Media on left, Content on right -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <!-- Media View with Ad Badge overlay (left side - 55% width) -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="55">

            <com.google.android.gms.ads.nativead.MediaView
                android:id="@+id/ad_media"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop" />

            <!-- Ad Badge overlay at top-right -->
            <TextView
                android:id="@+id/ad_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:text="@string/ad_badge"
                android:textSize="9sp"
                android:textColor="@color/foundation_black"
                android:textStyle="bold"
                android:background="@drawable/bg_ad_badge"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:layout_margin="8dp" />
        </FrameLayout>

        <!-- Content area (right side - 45% width) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="45"
            android:orientation="vertical"
            android:background="@color/foundation_black_100"
            android:padding="12dp"
            android:gravity="center_vertical">

            <!-- Row 1: Icon + Title -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <ImageView
                    android:id="@+id/ad_icon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:scaleType="fitCenter"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="@string/ad_icon" />

                <TextView
                    android:id="@+id/ad_headline"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="13sp"
                    android:textColor="@color/foundation_white"
                    android:textStyle="bold"
                    android:maxLines="2"
                    android:ellipsize="end" />
            </LinearLayout>

            <!-- Row 2: Body text -->
            <TextView
                android:id="@+id/ad_body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/foundation_white_60"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginStart="40dp"
                android:layout_marginBottom="8dp" />

            <!-- Row 3: CTA Button -->
            <TextView
                android:id="@+id/ad_call_to_action"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:gravity="center"
                android:textSize="13sp"
                android:textColor="@color/foundation_black"
                android:textStyle="bold"
                android:background="@drawable/bg_cta_clean"
                android:paddingHorizontal="16dp"
                android:minWidth="72dp"
                android:layout_marginStart="40dp" />

            <!-- Optional: Advertiser name (hidden if not provided) -->
            <TextView
                android:id="@+id/ad_advertiser"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="9sp"
                android:textColor="@color/foundation_white_40"
                android:maxLines="1"
                android:ellipsize="end"
                android:visibility="gone" />

            <!-- Optional: Store name (hidden if not provided) -->
            <TextView
                android:id="@+id/ad_store"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="9sp"
                android:textColor="@color/foundation_white_40"
                android:maxLines="1"
                android:ellipsize="end"
                android:visibility="gone" />

            <!-- Optional: Ad choices container (hidden if not provided) -->
            <FrameLayout
                android:id="@+id/ad_choices_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.gms.ads.nativead.NativeAdView>
