<?xml version="1.0" encoding="utf-8"?>
<!--
Native Ad Layout: Big Bait
- ConstraintLayout with MediaView maintaining 4:3 aspect ratio across all device widths
- Top: Title box, Middle: Media (4:3 dynamic), Bottom: CTA button
- CLICKBAIT CTA button with primary theme color (taller for better clickability)
- Attention-grabbing design for maximum clicks
- Use case: High-monetization placements
-->
<com.google.android.gms.ads.nativead.NativeAdView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#1E1E1E">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="304dp">

        <!-- Invisible Space to enforce container 412:304 ratio (original design) -->
        <Space
            android:id="@+id/ratio_enforcer"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintDimensionRatio="W,412:304" />

        <!-- Title box (icon + text) at top - minimal spacing -->
        <LinearLayout
            android:id="@+id/title_section"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#1E1E1E"
            android:paddingHorizontal="8dp"
            android:paddingVertical="6dp"
            android:gravity="center_vertical"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- App Icon -->
            <ImageView
                android:id="@+id/ad_icon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:scaleType="fitCenter"
                android:layout_marginEnd="8dp" />

            <!-- Text container -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- Headline row with ad badge -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/ad_headline"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="13sp"
                        android:textColor="#E0E0E0"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end" />

                </LinearLayout>

                <!-- Body text (1 line to prioritize CTA) -->
                <TextView
                    android:id="@+id/ad_body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="#999999"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>
        </LinearLayout>

        <!-- Media View (4:3 aspect ratio maintained across all device widths) -->
        <com.google.android.gms.ads.nativead.MediaView
            android:id="@+id/ad_media"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:scaleType="centerCrop"
            app:layout_constraintTop_toBottomOf="@id/title_section"
            app:layout_constraintBottom_toTopOf="@id/ad_call_to_action"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintDimensionRatio="W,4:3" />

        <!-- Clickable full-width CTA Button at bottom (Clickbait style) -->
        <TextView
            android:id="@+id/ad_call_to_action"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:gravity="center"
            android:textSize="18sp"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:background="@drawable/bg_cta_clean"
            android:layout_marginHorizontal="6dp"
            android:layout_marginVertical="5dp"
            app:layout_constraintTop_toBottomOf="@id/ad_media"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Ad badge at top-left (required by AdMob policy) -->
    <TextView
        android:id="@+id/ad_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="8dp"
        android:text="Ad"
        android:textSize="9sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:background="@drawable/bg_ad_badge"
        android:paddingHorizontal="6dp"
        android:paddingVertical="2dp" />

    <!-- AdChoices overlay at top-right of entire ad -->
    <FrameLayout
        android:id="@+id/ad_choices_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:padding="4dp" />
</com.google.android.gms.ads.nativead.NativeAdView>
