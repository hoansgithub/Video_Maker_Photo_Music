<?xml version="1.0" encoding="utf-8"?>
<!--
Native Ad Layout: Big Clean
- Large vertical layout (304dp height)
- Media fills top (variable height), content at bottom (wraps content)
- Clean CTA button on right side
- Dark background with ad badge
- Use case: Dedicated ad placements (language screen, settings screen)
-->
<com.google.android.gms.ads.nativead.NativeAdView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="304dp"
    android:background="@color/foundation_black">

    <!-- Vertical layout: Media fills top, content at bottom -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Media View (fills available space above content) -->
        <com.google.android.gms.ads.nativead.MediaView
            android:id="@+id/ad_media"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scaleType="centerCrop" />

        <!-- Content section (bottom - wraps content) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/foundation_black_100"
            android:padding="12dp"
            android:gravity="center_vertical">

            <!-- App Icon -->
            <ImageView
                android:id="@+id/ad_icon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:scaleType="fitCenter"
                android:layout_marginEnd="12dp"
                android:contentDescription="@string/ad_icon" />

            <!-- Text container (left side) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="12dp">

                <!-- Headline row with ad badge -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/ad_headline"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="14sp"
                        android:textColor="@color/foundation_white"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/ad_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ad_badge"
                        android:textSize="9sp"
                        android:textColor="@color/foundation_black"
                        android:textStyle="bold"
                        android:background="@drawable/bg_ad_badge"
                        android:paddingHorizontal="6dp"
                        android:paddingVertical="2dp"
                        android:layout_marginStart="6dp" />
                </LinearLayout>

                <!-- Body text -->
                <TextView
                    android:id="@+id/ad_body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/foundation_white_60"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:layout_marginTop="2dp" />

                <!-- Optional: Advertiser name (hidden if not provided) -->
                <TextView
                    android:id="@+id/ad_advertiser"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="9sp"
                    android:textColor="@color/foundation_white_40"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:visibility="gone" />

                <!-- Optional: Store name (hidden if not provided) -->
                <TextView
                    android:id="@+id/ad_store"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="9sp"
                    android:textColor="@color/foundation_white_40"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- CTA Button (right side) -->
            <TextView
                android:id="@+id/ad_call_to_action"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:gravity="center"
                android:textSize="12sp"
                android:textColor="@color/foundation_black"
                android:textStyle="bold"
                android:background="@drawable/bg_cta_clean"
                android:paddingHorizontal="16dp"
                android:minWidth="72dp" />

            <!-- Optional: Ad choices container (hidden if not provided) -->
            <FrameLayout
                android:id="@+id/ad_choices_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.gms.ads.nativead.NativeAdView>
