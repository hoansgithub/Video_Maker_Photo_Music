<?xml version="1.0" encoding="utf-8"?>
<!--
Native Ad Layout: Fullscreen Clean
- Follows Google AdMob Fullscreen Native Ad Guidelines
  https://developers.google.com/admob/android/native/full-screen
- Fullscreen layout (match_parent) with media background
- PORTRAIT aspect ratio is automatically requested via NativeAdOptions (MediaAspectRatio.PORTRAIT)
- In AdMob console, enable "Video" media type for better performance
- AdChoices overlay positioned at top-right
- Media View: MATCH_PARENT for consistent sizing (supports video)
- Top: Headline + body in semi-transparent card (72dp from top)
- Bottom: Icon + advertiser info + small CTA button (80dp from bottom)
- Professional, non-clickbait design
- Use case: Onboarding, interstitial ad placements
-->
<com.google.android.gms.ads.nativead.NativeAdView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/foundation_black">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Media View (fullscreen background, supports video) -->
        <com.google.android.gms.ads.nativead.MediaView
            android:id="@+id/ad_media"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:scaleType="centerCrop" />

        <!-- AdChoices overlay (top-right corner as per Google guidelines) -->
        <FrameLayout
            android:id="@+id/ad_choices_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_margin="8dp"
            android:minWidth="15dp"
            android:minHeight="15dp" />

        <!-- Top overlay card (headline + body) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:layout_marginTop="72dp"
            android:layout_marginHorizontal="16dp"
            android:orientation="vertical"
            android:background="@drawable/bg_native_overlay_card"
            android:padding="16dp">

            <!-- Headline -->
            <TextView
                android:id="@+id/ad_headline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end" />

            <!-- Body text -->
            <TextView
                android:id="@+id/ad_body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#E6FFFFFF"
                android:maxLines="3"
                android:ellipsize="end"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- Bottom info card (icon + advertiser info + CTA) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_marginBottom="80dp"
            android:layout_marginHorizontal="16dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_native_info_card"
            android:padding="12dp"
            android:gravity="center_vertical">

            <!-- App Icon -->
            <ImageView
                android:id="@+id/ad_icon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:scaleType="fitCenter"
                android:layout_marginEnd="12dp"
                android:contentDescription="@string/ad_icon" />

            <!-- Text container (left side) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="12dp">

                <TextView
                    android:id="@+id/ad_advertiser"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@color/foundation_white"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/ad_store"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/foundation_white_60"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Small CTA Button (right side, away from AdChoices) -->
            <TextView
                android:id="@+id/ad_call_to_action"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:gravity="center"
                android:textSize="12sp"
                android:textColor="@color/foundation_black"
                android:textStyle="bold"
                android:background="@drawable/bg_cta_clean"
                android:paddingHorizontal="16dp"
                android:minWidth="72dp" />
        </LinearLayout>
    </FrameLayout>
</com.google.android.gms.ads.nativead.NativeAdView>
